{
  "name": "reaper-mcp-ai-analyzing",
  "version": "1.0.0",
  "description": "MCP server for REAPER DAW with AI-powered audio analysis - FX management, parameter control, and intelligent mix suggestions",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "reaper-mcp-ai-analyzing": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "dev": "tsc --watch",
    "start": "node build/index.js",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "reaper",
    "daw",
    "audio",
    "music-production",
    "model-context-protocol",
    "ai-analysis",
    "mixing",
    "mastering"
  ],
  "author": "[Your Name]",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/[your-username]/reaper-mcp-ai-analyzing.git"
  },
  "bugs": {
    "url": "https://github.com/[your-username]/reaper-mcp-ai-analyzing/issues"
  },
  "homepage": "https://github.com/[your-username]/reaper-mcp-ai-analyzing#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.4.0",
    "dotenv": "^17.3.1",
    "fluent-ffmpeg": "^2.1.3",
    "openai": "^6.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}